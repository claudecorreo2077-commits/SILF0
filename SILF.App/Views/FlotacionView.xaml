<!-- Ruta: D:\ARCHIVOS\POTOSI\SILF\SILF.App\Views\FlotacionView.xaml -->
<UserControl x:Class="SILF.App.Views.FlotacionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <Style x:Key="ColRight" TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
        <!-- Header con fondo distinto -->
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
            <Setter Property="Background" Value="#37474F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
        </Style>
    </UserControl.Resources>
    <DockPanel>
        <!-- BARRA SUPERIOR -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" ItemsSource="{Binding FiltrosProceso}" SelectedItem="{Binding FiltroProceso}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}" md:HintAssist.Hint="Proceso"
                      md:HintAssist.FloatingScale="0.8" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding FiltrosMina}" SelectedItem="{Binding FiltroMina}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}" md:HintAssist.Hint="Mina"
                      md:HintAssist.FloatingScale="0.8" Margin="0,0,8,0"/>
            <TextBox Grid.Column="2" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     md:HintAssist.Hint="Buscar por proveedor, cooperativa, lote..."
                     md:TextFieldAssist.HasLeadingIcon="True" md:TextFieldAssist.LeadingIcon="Magnify" Margin="0,0,8,0"/>
            <Button Grid.Column="3" Command="{Binding ExportarExcelCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}" md:ButtonAssist.CornerRadius="6" Padding="16,6">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="FileExcel" Width="18" Height="18" Margin="0,0,6,0"/>
                    <TextBlock Text="Excel" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- RESUMEN -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                <StackPanel><TextBlock Text="Registros" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock Text="{Binding CantidadRegistros}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/></StackPanel></Border>
            <Border Grid.Column="1" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="12" Margin="6,0">
                <StackPanel><TextBlock Text="Valor Comercial" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock Text="{Binding TotalValorComercial, StringFormat='Bs {0:N2}'}" FontSize="14" FontWeight="Bold"/></StackPanel></Border>
            <Border Grid.Column="2" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="12" Margin="6,0">
                <StackPanel><TextBlock Text="Total Deducciones" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock Text="{Binding TotalDeducciones, StringFormat='Bs {0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="#C62828"/></StackPanel></Border>
            <Border Grid.Column="3" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="12" Margin="6,0">
                <StackPanel><TextBlock Text="Líquido Pagable" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock Text="{Binding TotalLiquidoPagable, StringFormat='Bs {0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/></StackPanel></Border>
            <Border Grid.Column="4" Background="{DynamicResource MaterialDesignCardBackground}" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                <StackPanel><TextBlock Text="Laboratorio" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock Text="{Binding TotalLaboratorio, StringFormat='Bs {0:N2}'}" FontSize="14" FontWeight="Bold"/></StackPanel></Border>
        </Grid>

        <!-- TABLA CONSOLIDADA -->
        <md:Card md:ElevationAssist.Elevation="Dp1" Padding="0">
            <DataGrid ItemsSource="{Binding RegistrosView}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeColumns="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource MaterialDesignDivider}"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      RowStyle="{StaticResource MaterialDesignDataGridRow}"
                      CellStyle="{StaticResource MaterialDesignDataGridCell}"
                      ColumnHeaderStyle="{StaticResource HeaderStyle}"
                      FontSize="11">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N°" Binding="{Binding NumeroEnProceso}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="PROCESO" Binding="{Binding ProcesoLabel}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="TICKET" Binding="{Binding Ticket}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="F. INGRESO" Binding="{Binding FechaIngreso, StringFormat='{}{0:dd/MM/yy}'}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="F. LIQUIDACIÓN" Binding="{Binding FechaLiquidacion, StringFormat='{}{0:dd/MM/yy}'}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="COOPERATIVA" Binding="{Binding Cooperativa}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="MINA" Binding="{Binding Mina}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="N° LOTE" Binding="{Binding NumeroLote}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="PROVEEDOR" Binding="{Binding Proveedor}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="PLACA" Binding="{Binding Placa}" Width="SizeToHeader"/>
                    <DataGridTextColumn Header="BRUTO" Binding="{Binding PesoBruto, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="TARA" Binding="{Binding Tara, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="NETO" Binding="{Binding PesoNeto, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="ZN" Binding="{Binding LeyZn, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="AG" Binding="{Binding LeyAg, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="PB" Binding="{Binding LeyPb, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="VALOR TOTAL" Binding="{Binding ValorComercial, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="REGALÍAS" Binding="{Binding Regalias, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="CNS" Binding="{Binding CNS, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="COMIBOL" Binding="{Binding COMIBOL, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="FENCOMIN" Binding="{Binding FENCOMIN, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="FEDECOMIN" Binding="{Binding FEDECOMIN, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="COOPERATIVA" Binding="{Binding Cooperativa_Ded, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="IUE" Binding="{Binding IUE, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="TOTAL DEDUCCIONES" Binding="{Binding TotalDeducciones, StringFormat='{}{0:N2}'}" Width="SizeToHeader">
                        <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Foreground" Value="#C62828"/></Style></DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="BONO TRANSPORTE" Binding="{Binding BonoTransporte, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                    <DataGridTextColumn Header="LÍQUIDO PAGABLE" Binding="{Binding LiquidoPagable, StringFormat='{}{0:N2}'}" Width="SizeToHeader">
                        <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="FontWeight" Value="Bold"/><Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/></Style></DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="LABORATORIO" Binding="{Binding CostoLaboratorio, StringFormat='{}{0:N2}'}" Width="SizeToHeader" ElementStyle="{StaticResource ColRight}"/>
                </DataGrid.Columns>
            </DataGrid>
        </md:Card>
    </DockPanel>
</UserControl>
