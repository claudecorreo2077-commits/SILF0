<!-- Ruta: D:\ARCHIVOS\POTOSI\SILF\SILF.App\Views\ProveedoresView.xaml -->
<UserControl x:Class="SILF.App.Views.ProveedoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FontFamily="Segoe UI"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- ═══════════════════════════════════════════
             CAPA 1: CONTENIDO PRINCIPAL
             ═══════════════════════════════════════════ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── BARRA SUPERIOR: Buscar + Contador + Botón Nuevo ── -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Buscador -->
                <TextBox Grid.Column="0" Width="300"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="13" materialDesign:HintAssist.Hint="Buscar por CI, nombre o cooperativa..."
                         materialDesign:HintAssist.FloatingScale="0.85"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                         Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Contador -->
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0"
                           FontSize="12" Opacity="0.5" FontFamily="Montserrat">
                    <Run Text="{Binding TotalProveedores, Mode=OneWay}"/>
                    <Run Text="proveedores"/>
                </TextBlock>

                <!-- Botón Nuevo -->
                <Button Grid.Column="2"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{DynamicResource MaterialDesign.Brush.Primary}"
                        Command="{Binding NuevoProveedorCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" Width="18" Height="18"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo Proveedor" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ── DATAGRID ── -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Proveedores}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      FontSize="13"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                      materialDesign:DataGridAssist.CornerRadius="8"
                      materialDesign:DataGridAssist.CellPadding="14 10">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="CI / NIT" Binding="{Binding CiNit}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Nombre Completo" Binding="{Binding NombreCompleto}" Width="*"/>

                    <DataGridTextColumn Header="Cooperativa" Binding="{Binding CooperativaNombre}" Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Lotes" Binding="{Binding CantidadLotes}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <!-- Columna de acciones -->
                    <DataGridTemplateColumn Header="" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Width="32" Height="32" ToolTip="Editar"
                                            Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                            Command="{Binding DataContext.EditarProveedorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Width="32" Height="32" ToolTip="Eliminar"
                                            Foreground="#E57373"
                                            Command="{Binding DataContext.PedirEliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ═══════════════════════════════════════════
             CAPA 2: OVERLAY OSCURO (cuando hay diálogo)
             ═══════════════════════════════════════════ -->
        <Border Background="#80000000" Visibility="{Binding DialogoAbierto, Converter={StaticResource BoolToVis}}"
                MouseDown="Overlay_MouseDown"/>

        <!-- ═══════════════════════════════════════════
             CAPA 3: DIÁLOGO CREAR / EDITAR PROVEEDOR
             ═══════════════════════════════════════════ -->
        <Border Visibility="{Binding DialogoAbierto, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="16" Padding="32" MinWidth="420" MaxWidth="500">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.3" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <!-- Título -->
                <TextBlock Text="{Binding DialogoTitulo}" FontSize="18" FontWeight="SemiBold"
                           FontFamily="Montserrat" Margin="0,0,0,20"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>

                <!-- CI/NIT -->
                <TextBlock Text="CI / NIT" FontSize="12" FontFamily="Montserrat" FontWeight="Medium"
                           Opacity="0.6" Margin="0,0,0,5"/>
                <TextBox FontSize="13" materialDesign:HintAssist.Hint="Cédula o NIT del proveedor"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.FloatingScale="0.85"
                         Text="{Binding EditCiNit, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Nombre -->
                <TextBlock Text="Nombre Completo" FontSize="12" FontFamily="Montserrat" FontWeight="Medium"
                           Opacity="0.6" Margin="0,16,0,5"/>
                <TextBox FontSize="13" materialDesign:HintAssist.Hint="Nombre del proveedor"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.FloatingScale="0.85"
                         Text="{Binding EditNombre, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Cooperativa -->
                <TextBlock Text="Cooperativa" FontSize="12" FontFamily="Montserrat" FontWeight="Medium"
                           Opacity="0.6" Margin="0,16,0,5"/>
                <ComboBox FontSize="13" ItemsSource="{Binding Cooperativas}" SelectedItem="{Binding EditCooperativa}"
                          DisplayMemberPath="Nombre"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="Seleccionar (opcional)"/>

                <!-- Error -->
                <TextBlock Text="{Binding MensajeError}" Foreground="#E57373" FontSize="12"
                           Margin="0,12,0,0" TextWrapping="Wrap"
                           Visibility="{Binding TieneError, Converter={StaticResource BoolToVis}}"/>

                <!-- Botones -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                    <Button Content="Cancelar" Margin="0,0,12,0"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CancelarDialogoCommand}"/>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource MaterialDesign.Brush.Primary}"
                            Command="{Binding GuardarProveedorCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Guardar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════
             CAPA 4: OVERLAY CONFIRMAR ELIMINAR
             ═══════════════════════════════════════════ -->
        <Border Background="#80000000"
                Visibility="{Binding ConfirmarEliminarAbierto, Converter={StaticResource BoolToVis}}"/>

        <Border Visibility="{Binding ConfirmarEliminarAbierto, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="16" Padding="32" MinWidth="380" MaxWidth="440">
            <Border.Effect>
                <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.3" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="AlertCircle" Width="24" Height="24"
                                             Foreground="#FFA726" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Confirmar" FontSize="18" FontWeight="SemiBold"
                               FontFamily="Montserrat"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
                </StackPanel>

                <TextBlock Text="{Binding MensajeConfirmacion}" FontSize="13"
                           TextWrapping="Wrap" Margin="0,0,0,24" Opacity="0.8"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Margin="0,0,12,0"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CancelarEliminarCommand}"/>
                    <!-- Solo mostrar botón Eliminar si hay _eliminandoId (tiene 0 lotes) -->
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#E57373"
                            Command="{Binding ConfirmarEliminarCommand}"
                            Visibility="{Binding PuedeEliminar, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Eliminar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
