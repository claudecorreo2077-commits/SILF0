<!-- Ruta: D:\ARCHIVOS\POTOSI\SILF\SILF.App\Views\ConcentradoWizardView.xaml -->
<UserControl x:Class="SILF.App.Views.ConcentradoWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:b="clr-namespace:SILF.App.Behaviors"
             xmlns:conv="clr-namespace:SILF.App.Converters"
             FontFamily="Segoe UI"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:RequiredFieldConverter x:Key="Req"/>
        <conv:PercentInputConverter x:Key="Pct"/>
        <conv:StepVisibilityConverter x:Key="StepVis"/>
        <conv:StepActiveOpacityConverter x:Key="StepOp"/>

        <Style x:Key="Sec" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Montserrat"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        <Style x:Key="FL" TargetType="TextBlock"><Setter Property="FontSize" Value="11"/><Setter Property="Opacity" Value="0.65"/><Setter Property="Margin" Value="0,0,0,3"/></Style>
        <Style x:Key="FI" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"><Setter Property="FontSize" Value="13"/><Setter Property="Margin" Value="0,0,10,8"/></Style>
        <Style x:Key="NUM" TargetType="TextBox" BasedOn="{StaticResource FI}"><Setter Property="b:NumericInput.IsEnabled" Value="True"/><Setter Property="HorizontalContentAlignment" Value="Right"/></Style>
        <Style x:Key="CLbl" TargetType="TextBlock"><Setter Property="FontSize" Value="12"/><Setter Property="Opacity" Value="0.85"/><Setter Property="VerticalAlignment" Value="Center"/></Style>
        <Style x:Key="CVal" TargetType="TextBlock"><Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="VerticalAlignment" Value="Center"/></Style>
        <Style x:Key="Chk" TargetType="CheckBox"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/></Style>
        <Style x:Key="Rate" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}"><Setter Property="FontSize" Value="12"/><Setter Property="HorizontalContentAlignment" Value="Right"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Margin" Value="0"/></Style>
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/><Setter Property="Padding" Value="12,5"/><Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <!-- ════ INDICADOR DE PASOS ════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,12" VerticalAlignment="Center">
            <Border Style="{StaticResource Chip}" Opacity="{Binding Paso, Converter={StaticResource StepOp}, ConverterParameter=1}">
                <TextBlock Text="1 · Cliente" Foreground="White" FontSize="12" FontWeight="SemiBold"/></Border>
            <Border Style="{StaticResource Chip}" Opacity="{Binding Paso, Converter={StaticResource StepOp}, ConverterParameter=2}">
                <TextBlock Text="2 · Análisis" Foreground="White" FontSize="12" FontWeight="SemiBold"/></Border>
            <Border Style="{StaticResource Chip}" Opacity="{Binding Paso, Converter={StaticResource StepOp}, ConverterParameter=3}">
                <TextBlock Text="3 · Cotizaciones" Foreground="White" FontSize="12" FontWeight="SemiBold"/></Border>
            <Border Style="{StaticResource Chip}" Margin="0" Opacity="{Binding Paso, Converter={StaticResource StepOp}, ConverterParameter=4}">
                <TextBlock Text="4 · Resultado" Foreground="White" FontSize="12" FontWeight="SemiBold"/></Border>
            <TextBlock Text="{Binding TituloFormulario}" Opacity="0.6" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="2,0,16,0">
            <Grid>

                <!-- ═══════════ PASO 1: CLIENTE Y LOTE ═══════════ -->
                <materialDesign:Card Visibility="{Binding Paso, Converter={StaticResource StepVis}, ConverterParameter=1}"
                                     Padding="22,18" UniformCornerRadius="12" HorizontalAlignment="Center" MaxWidth="680" VerticalAlignment="Top" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Sec}" Text="¿Para quién es la liquidación?" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FL}" Text="Nombre del cliente"/>
                                <TextBox Style="{StaticResource FI}" CharacterCasing="Upper" BorderBrush="{Binding ClienteNombre, Converter={StaticResource Req}}" Text="{Binding ClienteNombre, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Style="{StaticResource FL}" Text="Procedencia"/>
                                <TextBox Style="{StaticResource FI}" CharacterCasing="Upper" Text="{Binding Procedencia, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Style="{StaticResource FL}" Text="N° NIT / NIM / CI"/>
                                <TextBox Style="{StaticResource FI}" Text="{Binding ClienteCi, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Style="{StaticResource FL}" Text="Concesión minera"/>
                                <TextBox Style="{StaticResource FI}" CharacterCasing="Upper" Text="{Binding ConcesionMinera, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource FL}" Text="Liquidación N° (automático)"/>
                                <TextBox Style="{StaticResource FI}" CharacterCasing="Upper" IsReadOnly="True" Opacity="0.7" Text="{Binding NumeroLiquidacion}"/>
                                <TextBlock Style="{StaticResource FL}" Text="Municipio"/>
                                <TextBox Style="{StaticResource FI}" CharacterCasing="Upper" Text="{Binding Municipio, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Style="{StaticResource FL}" Text="Fecha de entrega"/>
                                <DatePicker Margin="0,0,10,8" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Style="{StaticResource MaterialDesignOutlinedDatePicker}" SelectedDate="{Binding FechaEntrega}"/>
                                <TextBlock Style="{StaticResource FL}" Text="Fecha de liquidación"/>
                                <DatePicker Margin="0,0,10,8" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Style="{StaticResource MaterialDesignOutlinedDatePicker}" SelectedDate="{Binding FechaLiquidacion}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ═══════════ PASO 2: ANÁLISIS ═══════════ -->
                <materialDesign:Card Visibility="{Binding Paso, Converter={StaticResource StepVis}, ConverterParameter=2}"
                                     Padding="22,18" UniformCornerRadius="12" HorizontalAlignment="Center" MaxWidth="720" VerticalAlignment="Top" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Sec}" Text="Análisis del lote" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="TMH (peso húmedo)"/>
                                <TextBox Style="{StaticResource NUM}" BorderBrush="{Binding Tmh, Converter={StaticResource Req}}" Text="{Binding Tmh, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="Humedad (%)"/>
                                <TextBox Style="{StaticResource NUM}" Text="{Binding PorcentajeHumedad, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FL}" Text="Merma (%)"/>
                                <TextBox Style="{StaticResource NUM}" Text="{Binding PorcentajeMerma, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                        </Grid>

                        <TextBlock Style="{StaticResource Sec}" Text="Leyes"/>
                        <!-- ZN-AG -->
                        <Grid Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="Ley ZN (%)"/>
                                <TextBox Style="{StaticResource NUM}" BorderBrush="{Binding LeyZn, Converter={StaticResource Req}}" Text="{Binding LeyZn, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="Ley AG (g·oz, sin %)"/>
                                <TextBox Style="{StaticResource NUM}" BorderBrush="{Binding LeyAg, Converter={StaticResource Req}}" Text="{Binding LeyAg, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                            <StackPanel Grid.Column="2"/>
                        </Grid>
                        <!-- AG-PB -->
                        <Grid Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="Ley AG (g·oz, sin %)"/>
                                <TextBox Style="{StaticResource NUM}" BorderBrush="{Binding LeyAg, Converter={StaticResource Req}}" Text="{Binding LeyAg, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="Ley PB (%)"/>
                                <TextBox Style="{StaticResource NUM}" BorderBrush="{Binding LeyPb, Converter={StaticResource Req}}" Text="{Binding LeyPb, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="2"/>
                        </Grid>

                        <TextBlock Style="{StaticResource Sec}" Text="Impurezas (%)"/>
                        <!-- ZN-AG impurezas -->
                        <Grid Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="Fe"/><TextBox Style="{StaticResource NUM}" Text="{Binding Fe, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="As"/><TextBox Style="{StaticResource NUM}" Text="{Binding As, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FL}" Text="Sb"/><TextBox Style="{StaticResource NUM}" Text="{Binding Sb, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="3"><TextBlock Style="{StaticResource FL}" Text="Sn"/><TextBox Style="{StaticResource NUM}" Text="{Binding Sn, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="4"><TextBlock Style="{StaticResource FL}" Text="SiO2"/><TextBox Style="{StaticResource NUM}" Text="{Binding SiO2, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                        </Grid>
                        <!-- AG-PB impurezas -->
                        <Grid Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="As"/><TextBox Style="{StaticResource NUM}" Text="{Binding As, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="Sb"/><TextBox Style="{StaticResource NUM}" Text="{Binding Sb, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FL}" Text="Bi"/><TextBox Style="{StaticResource NUM}" Text="{Binding Bi, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="3"><TextBlock Style="{StaticResource FL}" Text="Sn"/><TextBox Style="{StaticResource NUM}" Text="{Binding Sn, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="4"><TextBlock Style="{StaticResource FL}" Text="SiO2"/><TextBox Style="{StaticResource NUM}" Text="{Binding SiO2, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            <StackPanel Grid.Column="5"><TextBlock Style="{StaticResource FL}" Text="Zn"/><TextBox Style="{StaticResource NUM}" Text="{Binding ZnImpureza, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- ═══════════ PASO 3: COTIZACIONES Y DEDUCCIONES ═══════════ -->
                <Grid Visibility="{Binding Paso, Converter={StaticResource StepVis}, ConverterParameter=3}" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0" Padding="18,12,18,14" UniformCornerRadius="12" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Sec}" Text="Cotizaciones del día y T/C"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}"><TextBlock Style="{StaticResource FL}" Text="Cotización ZN ($/lb)"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding CotizZnLb, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                <StackPanel Grid.Column="0" Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}"><TextBlock Style="{StaticResource FL}" Text="Cotización PB ($/lb)"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding CotizPbLb, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="Cotización AG ($/oz)"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding CotizAgOz, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="T/C Oficial"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding TcOficial, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="T/C Comercial"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding TcComercial, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource Sec}" Text="Alícuotas y cotización de regalía"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}"><TextBlock Style="{StaticResource FL}" Text="Alícuota ZN (%)"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding AlicuotaZn, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                                <StackPanel Grid.Column="0" Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}"><TextBlock Style="{StaticResource FL}" Text="Alícuota PB (%)"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding AlicuotaPb, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="Alícuota AG (%)"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding AlicuotaAg, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}"><TextBlock Style="{StaticResource FL}" Text="Reg. ZN ($/lb)"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding CotizRegaliaZn, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                <StackPanel Grid.Column="0" Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}"><TextBlock Style="{StaticResource FL}" Text="Reg. PB ($/lb)"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding CotizRegaliaPb, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="Reg. AG ($/oz)"/>
                                    <TextBox Style="{StaticResource NUM}" Text="{Binding CotizRegaliaAg, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource FL}" Text="Anticipo (Bs)" Margin="0,6,0,3"/>
                            <TextBox Style="{StaticResource NUM}" HorizontalAlignment="Left" Width="160" Text="{Binding Anticipo, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="2" Padding="18,12,18,14" UniformCornerRadius="12" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Sec}" Text="¿Qué se aplica? (deducciones)"/>
                            <Grid Margin="0,0,0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="2" Style="{StaticResource FL}" Text="Tasa %" HorizontalAlignment="Right"/></Grid>
                            <CheckBox Style="{StaticResource Chk}" Content="Regalía minera ZN" IsChecked="{Binding AplicaRegaliaZn}" Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}" Margin="0,3"/>
                            <CheckBox Style="{StaticResource Chk}" Content="Regalía minera AG" IsChecked="{Binding AplicaRegaliaAg}" Margin="0,3"/>
                            <CheckBox Style="{StaticResource Chk}" Content="Regalía minera PB" IsChecked="{Binding AplicaRegaliaPb}" Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}" Margin="0,3"/>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="COMIBOL" IsChecked="{Binding AplicaComibol}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding TasaComibol, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="C.N.S." IsChecked="{Binding AplicaCns}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding TasaCns, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="FEDECOMIN" IsChecked="{Binding AplicaFedecomin}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding TasaFedecomin, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="FENCOMIN" IsChecked="{Binding AplicaFencomin}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding TasaFencomin, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></Grid>
                            <Grid Margin="0,3" Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="C. Wilstermann" IsChecked="{Binding AplicaWilstermann}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding TasaWilstermann, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="Aporte cooperativa" IsChecked="{Binding AplicaAporteCoop}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding TasaAporteCoop, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></Grid>
                            <Grid Margin="0,3" Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="M-02" IsChecked="{Binding AplicaM02}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding TasaM02, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></Grid>

                            <TextBlock Style="{StaticResource Sec}" Text="Fletes / otros"/>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="Comisión bancaria (%)" IsChecked="{Binding AplicaComisionBancaria}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding ComisionBancariaTasa, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></Grid>
                            <Grid Margin="0,3" Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="Rollback ($us/TMH)" IsChecked="{Binding AplicaRollback}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding Rollback, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.##\}, ConverterCulture=en-US}"/></Grid>
                            <Grid Margin="0,3" Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="Transporte terrestre ($us/TMH)" IsChecked="{Binding AplicaTransporte}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding TransporteTerrestre, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.##\}, ConverterCulture=en-US}"/></Grid>
                            <Grid Margin="0,3" Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="AHK ($us/TMH)" IsChecked="{Binding AplicaAhk}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding Ahk, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.##\}, ConverterCulture=en-US}"/></Grid>
                            <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="64"/></Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Chk}" Content="Molienda ($us/TMH)" IsChecked="{Binding AplicaMolienda}"/>
                                <TextBox Grid.Column="1" Style="{StaticResource Rate}" Text="{Binding Molienda, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.##\}, ConverterCulture=en-US}"/></Grid>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- ═══════════ PASO 4: RESULTADO ═══════════ -->
                <Grid Visibility="{Binding Paso, Converter={StaticResource StepVis}, ConverterParameter=4}" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.15*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                    <!-- Desglose -->
                    <StackPanel Grid.Column="0">
                        <materialDesign:Card Padding="18,12,18,14" UniformCornerRadius="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Sec}" Text="Resumen del cálculo"/>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="TMS (peso neto seco)"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResTms, StringFormat=N3}"/></Grid>
                                <Grid Margin="0,2" Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Pagable ZN ($us)"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResPagableZn, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Pagable AG ($us)"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResPagableAg, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2" Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Pagable PB ($us)"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResPagablePb, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Maquila ($us)"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResMaquila, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2" Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Refinación ($us)"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResRefinacion, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Penalidades ($us)"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResPenalidades, StringFormat=N2}"/></Grid>
                                <Separator Margin="0,6" Opacity="0.3"/>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Valor FOB ($us)"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResValorFobUs, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Valor FOB (Bs)"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResValorFobBs, StringFormat=N2}"/></Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Padding="18,12,18,14" UniformCornerRadius="12">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Sec}" Text="Retenciones (Bs)"/>
                                <Grid Margin="0,2" Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Regalía ZN"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResRegaliaZn, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Regalía AG"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResRegaliaAg, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2" Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Regalía PB"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResRegaliaPb, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="COMIBOL"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResComibol, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="C.N.S."/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResCns, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="FEDECOMIN"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResFedecomin, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="FENCOMIN"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResFencomin, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Aporte cooperativa"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResAporteCoop, StringFormat=N2}"/></Grid>
                                <Separator Margin="0,6" Opacity="0.3"/>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Total retenciones" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding ResTotalRetenciones, StringFormat=N2}"/></Grid>
                                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CLbl}" Text="Anticipo"/><TextBlock Grid.Column="1" Style="{StaticResource CVal}" Text="{Binding Anticipo, StringFormat=N2}"/></Grid>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>

                    <!-- Líquido pagable + ajustes técnicos -->
                    <StackPanel Grid.Column="2">
                        <Border Background="{DynamicResource MaterialDesign.Brush.Primary}" CornerRadius="12" Padding="18,14" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="LÍQUIDO PAGABLE" Foreground="White" Opacity="0.85" FontSize="12"/>
                                <TextBlock Text="{Binding ResLiquidoPagableBs, StringFormat='Bs {0:N2}'}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ResLiquidoPagableUs, StringFormat='$us {0:N2}'}" Foreground="White" FontSize="13" Opacity="0.9"/>
                                <Separator Margin="0,8" Background="White" Opacity="0.3"/>
                                <TextBlock Text="{Binding ResSaldoPagarBs, StringFormat='Saldo a pagar:  Bs {0:N2}'}" Foreground="White" FontSize="13" Opacity="0.95"/>
                            </StackPanel>
                        </Border>

                        <materialDesign:Card Padding="18,12,18,14" UniformCornerRadius="12">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Sec}" Text="Ajustes (parámetros técnicos)"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="Maquila base"/>
                                        <TextBox Style="{StaticResource NUM}" Text="{Binding MaquilaBase, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="Maquila $us"/>
                                        <TextBox Style="{StaticResource NUM}" Text="{Binding MaquilaFijo, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="Escalador"/>
                                        <TextBox Style="{StaticResource NUM}" Text="{Binding MaquilaEscalador, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="Otros ajuste $us"/>
                                        <TextBox Style="{StaticResource NUM}" Text="{Binding OtrosAjusteUs, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                </Grid>
                                <!-- Pagables ZN-AG -->
                                <Grid Visibility="{Binding EsZnAg, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="ZN libre (%)"/><TextBox Style="{StaticResource NUM}" Text="{Binding ZnLibre, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="ZN factor (%)"/><TextBox Style="{StaticResource NUM}" Text="{Binding ZnFactor, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FL}" Text="AG libre (oz)"/><TextBox Style="{StaticResource NUM}" Text="{Binding AgLibreOz, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                    <StackPanel Grid.Column="3"><TextBlock Style="{StaticResource FL}" Text="AG factor (%)"/><TextBox Style="{StaticResource NUM}" Text="{Binding AgFactor, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                                </Grid>
                                <!-- Pagables AG-PB -->
                                <Grid Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"><TextBlock Style="{StaticResource FL}" Text="AG libre (oz)"/><TextBox Style="{StaticResource NUM}" Text="{Binding AgLibreOz, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Style="{StaticResource FL}" Text="AG factor (%)"/><TextBox Style="{StaticResource NUM}" Text="{Binding AgFactor, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Style="{StaticResource FL}" Text="PB libre (%)"/><TextBox Style="{StaticResource NUM}" Text="{Binding PbLibre, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                                    <StackPanel Grid.Column="3"><TextBlock Style="{StaticResource FL}" Text="PB factor (%)"/><TextBox Style="{StaticResource NUM}" Text="{Binding PbFactor, UpdateSourceTrigger=LostFocus, Converter={StaticResource Pct}}"/></StackPanel>
                                </Grid>
                                <StackPanel Visibility="{Binding EsAg, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Style="{StaticResource FL}" Text="Refinación AG ($/oz)"/>
                                    <TextBox Style="{StaticResource NUM}" HorizontalAlignment="Left" Width="140" Text="{Binding RefinacionAgPorOz, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/>
                                </StackPanel>

                                <TextBlock Style="{StaticResource FL}" Text="Penalidades (límite libre % · tarifa $us)" Margin="0,6,0,3"/>
                                <DataGrid ItemsSource="{Binding Penalidades}" AutoGenerateColumns="False" CanUserAddRows="False"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="Transparent" RowBackground="Transparent" MaxHeight="180">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="IMPUREZA" Binding="{Binding Nombre}" IsReadOnly="True" Width="*"/>
                                        <DataGridTextColumn Header="LIBRE (%)" Binding="{Binding Libre, Converter={StaticResource Pct}}" Width="100"/>
                                        <DataGridTextColumn Header="TARIFA $us" Binding="{Binding Tarifa, StringFormat=\{0:0.####\}}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Button Content="RECALCULAR" Command="{Binding CalcularCommand}" Margin="0,12,0,0" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                <Button Content="Cargar datos de muestra (comparar con Excel)" Command="{Binding CargarMuestraCommand}" Margin="0,8,0,0" FontSize="11" Style="{StaticResource MaterialDesignFlatButton}"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </Grid>

            </Grid>
        </ScrollViewer>

        <!-- ════ FOOTER / NAVEGACIÓN ════ -->
        <Grid Grid.Row="2" Margin="0,14,0,2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Cancelar" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding CancelarCommand}"/>
                <TextBlock Text="{Binding MensajeError}" Foreground="#E57373" FontSize="12" VerticalAlignment="Center" Margin="14,0,0,0"
                           MaxWidth="420" TextWrapping="Wrap" Visibility="{Binding TieneError, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Atrás" Margin="8,0,0,0" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding AtrasCommand}"
                        Visibility="{Binding MuestraAtras, Converter={StaticResource BoolToVis}}"/>
                <Button Content="Siguiente" Margin="8,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}" Background="{DynamicResource MaterialDesign.Brush.Primary}" Command="{Binding SiguienteCommand}"
                        Visibility="{Binding MuestraSiguiente, Converter={StaticResource BoolToVis}}"/>
                <Button Content="Calcular y ver resultado" Margin="8,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}" Background="{DynamicResource MaterialDesign.Brush.Primary}" Command="{Binding SiguienteCommand}"
                        Visibility="{Binding Paso, Converter={StaticResource StepVis}, ConverterParameter=3}"/>
                <Button Margin="8,0,0,0" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding EditarDatosCommand}"
                        Visibility="{Binding Paso, Converter={StaticResource StepVis}, ConverterParameter=4}">
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/><TextBlock Text="Editar datos" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button Margin="8,0,0,0" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding GenerarReciboCommand}"
                        Visibility="{Binding Paso, Converter={StaticResource StepVis}, ConverterParameter=4}">
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="FilePdfBox" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/><TextBlock Text="Recibo" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button Margin="8,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}" Background="{DynamicResource MaterialDesign.Brush.Primary}" Command="{Binding GuardarCommand}"
                        Visibility="{Binding Paso, Converter={StaticResource StepVis}, ConverterParameter=4}">
                    <StackPanel Orientation="Horizontal"><materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/><TextBlock Text="Guardar" VerticalAlignment="Center"/></StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
