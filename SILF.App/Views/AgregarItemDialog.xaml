<Window x:Class="SILF.App.Views.AgregarItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding TituloDialog}" Height="200" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False">

    <Border CornerRadius="12" BorderThickness="1" BorderBrush="#2A2060">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                <GradientStop Color="#0E0C35" Offset="0"/>
                <GradientStop Color="#1B1448" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid Margin="24,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Grid.Row="0" x:Name="TxtTitulo" Text="Agregar"
                       FontSize="16" FontWeight="SemiBold" FontFamily="Montserrat"
                       Foreground="White" Margin="0,0,0,14"/>

            <!-- Campo nombre -->
            <TextBlock Grid.Row="1" Text="Nombre:" Foreground="#90A4AE" FontSize="12"
                       FontFamily="Montserrat" Margin="0,0,0,4"/>
            <TextBox Grid.Row="2" x:Name="TxtNombre" FontSize="14" FontFamily="Segoe UI"
                     Foreground="White" CaretBrush="White"
                     BorderBrush="#462AD8" BorderThickness="0,0,0,2"
                     Background="Transparent" Height="30"
                     VerticalContentAlignment="Center"
                     Padding="4,0"/>

            <!-- Botones -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancelar" Foreground="#90A4AE" FontFamily="Montserrat" FontSize="12"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Padding="16,8" Click="BtnCancelar_Click"/>
                <Button Content="Guardar" Foreground="White" FontFamily="Montserrat" FontSize="12"
                        FontWeight="SemiBold" Cursor="Hand" Margin="8,0,0,0" Click="BtnGuardar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#462AD8" CornerRadius="8" Padding="18,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#5A3DE8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
