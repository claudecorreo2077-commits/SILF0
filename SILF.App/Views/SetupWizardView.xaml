<!-- Ruta: D:\ARCHIVOS\POTOSI\SILF\SILF.App\Views\SetupWizardView.xaml -->
<Window x:Class="SILF.App.Views.SetupWizardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="clr-namespace:SILF.App.Behaviors"
        Title="SILF — Configuración Inicial" Height="640" Width="500"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="WizardLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="DarkGray"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Margin" Value="0,14,0,4"/>
        </Style>

        <Style x:Key="WizardInput" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="LightGray"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="WizardPassword" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="LightGray"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="OptionalTag" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SummaryLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="DarkGray"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
        </Style>

        <Style x:Key="SummaryValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12">
        <Border.Background>
            <ImageBrush ImageSource="/Assets/Images/back-image.jpg" Stretch="None"/>
        </Border.Background>

        <Border CornerRadius="10" BorderThickness="2" Opacity="0.95">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#462AD8" Offset="0"/>
                    <GradientStop Color="#DA34AE" Offset="0.75"/>
                    <GradientStop Color="#8A16C1" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="#060531" Offset="0"/>
                    <GradientStop Color="#1B1448" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ═══ ROW 0: Barra superior ═══ -->
                <Grid Grid.Row="0">
                    <TextBlock Text="SILF — Configuración Inicial"
                               Foreground="DarkGray" FontSize="10"
                               FontFamily="Montserrat" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <Button HorizontalAlignment="Right" Margin="0,0,8,0" Click="btnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18" CornerRadius="9" Background="#DA34AE" x:Name="bd">
                                    <TextBlock Text="X" Foreground="White" FontSize="12"
                                               FontFamily="Montserrat" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#C62DAE"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ═══ ROW 1: Contenido scrollable (SIN botones) ═══ -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="40,5,40,10">

                        <!-- Logo + título -->
                        <Image Source="/Assets/Images/logo.png" Width="50" Height="50"/>
                        <TextBlock Text="Configuración Inicial" Foreground="White"
                                   FontSize="18" FontWeight="Medium" FontFamily="Montserrat"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>

                        <!-- Indicador de pasos -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,3">
                            <Ellipse Width="10" Height="10" Margin="4,0">
                                <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#444"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding EsPaso1}" Value="True"><Setter Property="Fill" Value="#462AD8"/></DataTrigger></Style.Triggers>
                                </Style></Ellipse.Style>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Margin="4,0">
                                <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#444"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding EsPaso2}" Value="True"><Setter Property="Fill" Value="#462AD8"/></DataTrigger></Style.Triggers>
                                </Style></Ellipse.Style>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Margin="4,0">
                                <Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="#444"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding EsPaso3}" Value="True"><Setter Property="Fill" Value="#462AD8"/></DataTrigger></Style.Triggers>
                                </Style></Ellipse.Style>
                            </Ellipse>
                        </StackPanel>

                        <!-- ═══════════════════════════════════════ -->
                        <!-- PASO 1: EMPRESA -->
                        <!-- ═══════════════════════════════════════ -->
                        <StackPanel Visibility="{Binding EsPaso1, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Datos de la Empresa" Foreground="#DA34AE"
                                       FontSize="14" FontFamily="Montserrat" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>

                            <TextBlock Text="Razón Social *" Style="{StaticResource WizardLabel}"/>
                            <TextBox Style="{StaticResource WizardInput}"
                                     Text="{Binding EmpresaNombre, UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,4">
                                <TextBlock Text="Municipio" Foreground="DarkGray" FontSize="12"
                                           FontWeight="Medium" FontFamily="Montserrat"/>
                                <TextBlock Text="(opcional)" Style="{StaticResource OptionalTag}"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource WizardInput}"
                                     Text="{Binding EmpresaMunicipio, UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,4">
                                <TextBlock Text="Ingenio" Foreground="DarkGray" FontSize="12"
                                           FontWeight="Medium" FontFamily="Montserrat"/>
                                <TextBlock Text="(opcional)" Style="{StaticResource OptionalTag}"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource WizardInput}"
                                     Text="{Binding EmpresaIngenio, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Dos tipos de cambio en una fila -->
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource WizardLabel}" Margin="0,0,0,4">
                                        <Run Text="T/C Regalías *"/>
                                        <LineBreak/>
                                        <Run Text="(ej: 6.96)" FontSize="10" FontStyle="Italic" Foreground="#888"/>
                                    </TextBlock>
                                    <TextBox Style="{StaticResource WizardInput}"
                                             b:NumericInput.IsEnabled="True"
                                             Text="{Binding TipoCambioRegalias, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource WizardLabel}" Margin="0,0,0,4">
                                        <Run Text="T/C General *"/>
                                        <LineBreak/>
                                        <Run Text="(ej: 6.90)" FontSize="10" FontStyle="Italic" Foreground="#888"/>
                                    </TextBlock>
                                    <TextBox Style="{StaticResource WizardInput}"
                                             b:NumericInput.IsEnabled="True"
                                             Text="{Binding TipoCambioGeneral, UpdateSourceTrigger=LostFocus, StringFormat=\{0:0.####\}, ConverterCulture=en-US}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Logo de la empresa" Style="{StaticResource WizardLabel}"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding SeleccionarLogoCommand}" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" CornerRadius="8" Padding="14,8"
                                                    BorderBrush="#462AD8" BorderThickness="1.5" Background="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📁" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Seleccionar imagen" Foreground="LightGray"
                                                               FontSize="11" FontFamily="Montserrat" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#15FFFFFF"/>
                                                    <Setter TargetName="bd" Property="BorderBrush" Value="#DA34AE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Border Grid.Column="1" Margin="16,0,0,0"
                                        Width="60" Height="60" CornerRadius="8"
                                        BorderBrush="#333" BorderThickness="1" HorizontalAlignment="Left"
                                        Visibility="{Binding TieneLogoCargado, Converter={StaticResource BoolToVis}}">
                                    <Image Source="{Binding LogoPreview}" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- ═══════════════════════════════════════ -->
                        <!-- PASO 2: ADMINISTRADOR -->
                        <!-- ═══════════════════════════════════════ -->
                        <StackPanel Visibility="{Binding EsPaso2, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Cuenta de Administrador" Foreground="#DA34AE"
                                       FontSize="14" FontFamily="Montserrat" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>

                            <TextBlock Text="Nombre Completo *" Style="{StaticResource WizardLabel}"/>
                            <TextBox Style="{StaticResource WizardInput}"
                                     Text="{Binding AdminNombreCompleto, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Nombre de Usuario *" Style="{StaticResource WizardLabel}"/>
                            <TextBox Style="{StaticResource WizardInput}"
                                     Text="{Binding AdminUsuario, UpdateSourceTrigger=PropertyChanged}"/>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Contraseña *" Foreground="DarkGray" FontSize="12"
                                           FontWeight="Medium" FontFamily="Montserrat"/>
                                <Button Grid.Column="1" Command="{Binding TogglePasswordCommand}" Cursor="Hand"
                                        ToolTip="Mostrar/ocultar contraseña">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock FontSize="16" Foreground="#666" Margin="0,0,4,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="👁"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding MostrarPassword}" Value="True">
                                                                <Setter Property="Text" Value="🔒"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <PasswordBox x:Name="PwdBox1" PasswordChanged="PwdBox1_Changed" Margin="0,4,0,0">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource WizardPassword}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MostrarPassword}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>
                            <TextBox Style="{StaticResource WizardInput}" Margin="0,4,0,0"
                                     Text="{Binding PasswordTextoVisible, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="PwdVisible1_Changed"
                                     Visibility="{Binding MostrarPassword, Converter={StaticResource BoolToVis}}"/>

                            <TextBlock Text="Confirmar Contraseña *" Style="{StaticResource WizardLabel}"/>
                            <PasswordBox x:Name="PwdBox2" PasswordChanged="PwdBox2_Changed">
                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox" BasedOn="{StaticResource WizardPassword}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MostrarPassword}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </PasswordBox.Style>
                            </PasswordBox>
                            <TextBox Style="{StaticResource WizardInput}"
                                     Text="{Binding ConfirmarPasswordTextoVisible, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="PwdVisible2_Changed"
                                     Visibility="{Binding MostrarPassword, Converter={StaticResource BoolToVis}}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                        Visibility="{Binding MostrarIndicadorMatch, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding PasswordMatchIcon}" FontSize="14" Margin="0,0,6,0"
                                           FontFamily="Montserrat" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#FF6B6B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PasswordsCoinciden}" Value="True">
                                                    <Setter Property="Foreground" Value="#66BB6A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="11" FontFamily="Montserrat" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Las contraseñas no coinciden"/>
                                            <Setter Property="Foreground" Value="#FF6B6B"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PasswordsCoinciden}" Value="True">
                                                    <Setter Property="Text" Value="Las contraseñas coinciden"/>
                                                    <Setter Property="Foreground" Value="#66BB6A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- ═══════════════════════════════════════ -->
                        <!-- PASO 3: RESUMEN -->
                        <!-- ═══════════════════════════════════════ -->
                        <StackPanel Visibility="{Binding EsPaso3, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Resumen de Configuración" Foreground="#DA34AE"
                                       FontSize="14" FontFamily="Montserrat" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>

                            <Border Margin="0,12,0,0" Width="80" Height="80" CornerRadius="10"
                                    BorderBrush="#333" BorderThickness="1" HorizontalAlignment="Center"
                                    Visibility="{Binding TieneLogoCargado, Converter={StaticResource BoolToVis}}">
                                <Image Source="{Binding LogoPreview}" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="0,10,0,6" Margin="0,8,0,0">
                                <TextBlock Text="EMPRESA" Foreground="#DA34AE" FontSize="11"
                                           FontFamily="Montserrat" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Razón Social" Style="{StaticResource SummaryLabel}" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding EmpresaNombre}" Style="{StaticResource SummaryValue}"/>
                            <TextBlock Text="Municipio / Ingenio" Style="{StaticResource SummaryLabel}"/>
                            <TextBlock Style="{StaticResource SummaryValue}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} / {1}">
                                        <Binding Path="EmpresaMunicipio"/>
                                        <Binding Path="EmpresaIngenio"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="T/C Regalías" Style="{StaticResource SummaryLabel}"/>
                            <TextBlock Text="{Binding TipoCambioRegalias, StringFormat={}{0:N4} Bs/$US}" Style="{StaticResource SummaryValue}"/>
                            <TextBlock Text="T/C General" Style="{StaticResource SummaryLabel}"/>
                            <TextBlock Text="{Binding TipoCambioGeneral, StringFormat={}{0:N4} Bs/$US}" Style="{StaticResource SummaryValue}"/>

                            <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="0,6,0,6">
                                <TextBlock Text="ADMINISTRADOR" Foreground="#DA34AE" FontSize="11"
                                           FontFamily="Montserrat" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="Nombre" Style="{StaticResource SummaryLabel}" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding AdminNombreCompleto}" Style="{StaticResource SummaryValue}"/>
                            <TextBlock Text="Usuario" Style="{StaticResource SummaryLabel}"/>
                            <TextBlock Text="{Binding AdminUsuario}" Style="{StaticResource SummaryValue}"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- ═══ ROW 2: Error + Botones (FUERA del ScrollViewer) ═══ -->
                <StackPanel Grid.Row="2" Margin="40,0,40,0">
                    <TextBlock Text="{Binding MensajeError}" Foreground="#FF6B6B"
                               FontSize="11" FontFamily="Montserrat" TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               Visibility="{Binding TieneError, Converter={StaticResource BoolToVis}}"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="← ATRÁS" Foreground="LightGray" FontSize="12" FontFamily="Montserrat"
                                Cursor="Hand" HorizontalAlignment="Left"
                                Command="{Binding RetrocederCommand}"
                                Visibility="{Binding PuedeRetroceder, Converter={StaticResource BoolToVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Padding="10,8" Background="Transparent" x:Name="bd">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#10FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="1" Content="{Binding TextoBotonSiguiente}"
                                Foreground="White" FontSize="12" FontFamily="Montserrat"
                                Cursor="Hand" HorizontalAlignment="Right"
                                Command="{Binding SiguienteCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="160" Height="40" CornerRadius="8" x:Name="bd" Background="#462AD8">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#28AEED"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>

            </Grid>
        </Border>
    </Border>
</Window>
