<!-- Ruta: D:\ARCHIVOS\POTOSI\SILF\SILF.App\Views\EmpresaView.xaml -->
<UserControl x:Class="SILF.App.Views.EmpresaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:b="clr-namespace:SILF.App.Behaviors"
             FontFamily="Segoe UI"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="FI" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.85"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
        <StackPanel MaxWidth="600" Margin="0,8,0,20">

            <!-- Logo -->
            <TextBlock Text="Logo de la Empresa" Style="{StaticResource FL}" FontWeight="SemiBold" FontSize="13" Opacity="0.9"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Border Width="100" Height="100" CornerRadius="12"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                        BorderThickness="2" Background="{DynamicResource MaterialDesign.Brush.Card.Background}" ClipToBounds="True">
                    <Grid>
                        <materialDesign:PackIcon Kind="ImageArea" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.2"/>
                        <Image Source="{Binding EmpLogoPath}" Stretch="Uniform" Margin="4"/>
                    </Grid>
                </Border>
                <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding SeleccionarLogoCommand}" FontSize="12" Padding="16,6">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Upload" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cambiar Logo" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="PNG o JPG, preferiblemente cuadrado" FontSize="11" Opacity="0.4" Margin="0,6,0,0"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Style="{StaticResource FL}" Text="Razón Social *"/>
            <TextBox Style="{StaticResource FI}" materialDesign:HintAssist.Hint="Nombre de la empresa"
                     Text="{Binding EmpRazonSocial, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Style="{StaticResource FL}" Text="NIT" Margin="0,14,0,5"/>
            <TextBox Style="{StaticResource FI}" materialDesign:HintAssist.Hint="Número de identificación tributaria"
                     Text="{Binding EmpNit, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Style="{StaticResource FL}" Text="Dirección" Margin="0,14,0,5"/>
            <TextBox Style="{StaticResource FI}" materialDesign:HintAssist.Hint="Dirección de la empresa"
                     Text="{Binding EmpDireccion, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Style="{StaticResource FL}" Text="Teléfono" Margin="0,14,0,5"/>
            <TextBox Style="{StaticResource FI}" materialDesign:HintAssist.Hint="Teléfono de contacto"
                     Text="{Binding EmpTelefono, UpdateSourceTrigger=PropertyChanged}"/>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FL}" Text="Municipio"/>
                    <TextBox Style="{StaticResource FI}" materialDesign:HintAssist.Hint="Ej: Porco"
                             Text="{Binding EmpMunicipio, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FL}" Text="Ingenio"/>
                    <TextBox Style="{StaticResource FI}" materialDesign:HintAssist.Hint="Ej: Villa Imperial"
                             Text="{Binding EmpIngenio, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <!-- Nombre del Liquidador -->
            <Border Margin="0,24,0,0" Padding="16" CornerRadius="8"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Nombre del Liquidador" FontSize="13" FontWeight="SemiBold" FontFamily="Montserrat"/>
                        <TextBlock Text="Aparece en la firma del reporte PDF de liquidación" FontSize="11" Opacity="0.5" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBox Grid.Column="1" Style="{StaticResource FI}"
                             materialDesign:HintAssist.Hint="Nombre completo"
                             Text="{Binding EmpNombreLiquidador, UpdateSourceTrigger=PropertyChanged}"
                             CharacterCasing="Upper"/>
                </Grid>
            </Border>

            <!-- Tipos de Cambio (2 cotizaciones) -->
            <Border Margin="0,24,0,0" Padding="16" CornerRadius="8"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Tipos de Cambio (USD → Bs)" FontSize="13" FontWeight="SemiBold" FontFamily="Montserrat"/>
                    <TextBlock Text="Se manejan dos cotizaciones distintas en los cálculos de liquidación"
                               FontSize="11" Opacity="0.5" Margin="0,2,0,14"/>

                    <!-- T/C Regalías -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="T/C para Regalías Mineras" FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Se aplica únicamente al cálculo de Regalías 6%"
                                       FontSize="11" Opacity="0.55" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Style="{StaticResource FI}"
                                 materialDesign:HintAssist.Hint="Ej: 6.9600"
                                 b:NumericInput.IsEnabled="True"
                                 Text="{Binding TipoCambioRegalias, StringFormat=\{0:0.0000\}, ConverterCulture=en-US, UpdateSourceTrigger=LostFocus}"
                                 HorizontalContentAlignment="Right" FontWeight="SemiBold" FontSize="15"/>
                    </Grid>

                    <!-- T/C General -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="T/C General" FontSize="13" FontWeight="Medium"/>
                            <TextBlock Text="Valor comercial, CNS, COMIBOL, FENCOMIN, FEDECOMIN, Cooperativa, IUE"
                                       FontSize="11" Opacity="0.55" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Style="{StaticResource FI}"
                                 materialDesign:HintAssist.Hint="Ej: 6.9000"
                                 b:NumericInput.IsEnabled="True"
                                 Text="{Binding TipoCambioGeneral, StringFormat=\{0:0.0000\}, ConverterCulture=en-US, UpdateSourceTrigger=LostFocus}"
                                 HorizontalContentAlignment="Right" FontWeight="SemiBold" FontSize="15"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Base de Datos (Exportar / Importar) -->
            <Border Margin="0,24,0,0" Padding="16" CornerRadius="8"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Base de Datos" FontSize="13" FontWeight="SemiBold" FontFamily="Montserrat"/>
                        <TextBlock Text="Exportar un respaldo o importar datos desde otra instalación" FontSize="11" Opacity="0.5" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ExportarBdCommand}"
                                FontSize="12" Padding="16,6" Margin="0,0,12,0"
                                materialDesign:ButtonAssist.CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseExport" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Exportar Respaldo" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ImportarBdCommand}"
                                FontSize="12" Padding="16,6"
                                materialDesign:ButtonAssist.CornerRadius="6"
                                Foreground="#FF7043" BorderBrush="#FF7043">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseImport" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Importar Base de Datos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Mensaje + Guardar -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <TextBlock Text="{Binding Mensaje}" FontSize="12" VerticalAlignment="Center"
                           Margin="0,0,16,0" Opacity="0.7"
                           Visibility="{Binding MensajeVisible, Converter={StaticResource BoolToVis}}"/>
                <Button Content="Cancelar" Margin="0,0,12,0"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding CargarDatosCommand}"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{DynamicResource MaterialDesign.Brush.Primary}" Command="{Binding GuardarCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Guardar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
