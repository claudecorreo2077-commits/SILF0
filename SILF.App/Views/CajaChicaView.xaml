<!-- Ruta: D:\ARCHIVOS\POTOSI\SILF\SILF.App\Views\CajaChicaView.xaml -->
<UserControl x:Class="SILF.App.Views.CajaChicaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:b="clr-namespace:SILF.App.Behaviors"
             xmlns:vm="clr-namespace:SILF.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:CajaChicaViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <md:DialogHost IsOpen="{Binding DialogoAbierto}" CloseOnClickAway="False"
                   OverlayBackground="{DynamicResource MaterialDesign.Brush.Background}">
        <md:DialogHost.DialogContent>
            <!-- ══════════════════════════════════════════ -->
            <!-- DIÁLOGO: CREAR / EDITAR RECIBO            -->
            <!-- ══════════════════════════════════════════ -->
            <Border MinWidth="520" MaxWidth="600" Padding="28,24">
                <StackPanel>
                    <TextBlock Text="{Binding DialogoTitulo}" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding FormNumeroFormateado}"
                                 md:HintAssist.Hint="Nº de Recibo" IsReadOnly="True"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 FontWeight="Bold"/>
                        <DatePicker Grid.Column="2"
                                    SelectedDate="{Binding FormFecha}"
                                    md:HintAssist.Hint="Fecha"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                    </Grid>

                    <ComboBox ItemsSource="{Binding TiposMovimiento}"
                              SelectedItem="{Binding FormTipoMovimiento}"
                              md:HintAssist.Hint="Tipo de Movimiento (cambiarlo reasigna el Nº)"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,12"/>

                    <ComboBox IsEditable="True" IsTextSearchEnabled="True"
                              ItemsSource="{Binding BeneficiariosAnteriores}"
                              Text="{Binding FormBeneficiario, UpdateSourceTrigger=PropertyChanged}"
                              md:HintAssist.Hint="{Binding LabelFormBeneficiario}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,12"/>

                    <TextBox Text="{Binding FormMonto, StringFormat=\{0:0.####\}, ConverterCulture=en-US, UpdateSourceTrigger=PropertyChanged}"
                             md:HintAssist.Hint="Valor (Bs)"
                             b:NumericInput.IsEnabled="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             FontWeight="SemiBold" FontSize="15"
                             Margin="0,0,0,4"/>

                    <TextBlock Text="{Binding FormMontoLetras}" FontSize="11"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                               TextWrapping="Wrap" Margin="4,0,0,12"
                               FontStyle="Italic"/>

                    <TextBox Text="{Binding FormConcepto, UpdateSourceTrigger=PropertyChanged}"
                             md:HintAssist.Hint="Por concepto de"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             AcceptsReturn="False" MaxLength="500"
                             Margin="0,0,0,12"/>

                    <ComboBox IsEditable="True" IsTextSearchEnabled="True"
                              ItemsSource="{Binding CuentasDisponibles}"
                              Text="{Binding FormCuenta, UpdateSourceTrigger=PropertyChanged}"
                              md:HintAssist.Hint="Cuenta (categoría)"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,12"/>

                    <TextBox Text="{Binding FormObservaciones, UpdateSourceTrigger=PropertyChanged}"
                             md:HintAssist.Hint="Observaciones"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="60" MaxHeight="100"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding MensajeError}" Foreground="Red"
                               FontSize="12" Margin="0,0,0,8"
                               Visibility="{Binding TieneError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="CANCELAR" Command="{Binding CancelarDialogoCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,12,0"/>
                        <Button Content="GUARDAR" Command="{Binding GuardarReciboCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </md:DialogHost.DialogContent>

        <md:DialogHost IsOpen="{Binding ConfirmarEliminarAbierto}" CloseOnClickAway="False"
                       OverlayBackground="{DynamicResource MaterialDesign.Brush.Background}">
            <md:DialogHost.DialogContent>
                <Border Padding="28,24" MinWidth="380">
                    <StackPanel>
                        <md:PackIcon Kind="AlertCircleOutline" Width="48" Height="48"
                                     Foreground="OrangeRed" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="Eliminar Recibo" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding MensajeConfirmacion}" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="CANCELAR" Command="{Binding CancelarEliminarCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,12,0"/>
                            <Button Content="ELIMINAR" Command="{Binding ConfirmarEliminarCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="OrangeRed"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </md:DialogHost.DialogContent>

            <DockPanel>
                <TabControl SelectedIndex="{Binding TabSeleccionado}"
                            md:ColorZoneAssist.Mode="PrimaryMid" TabStripPlacement="Top">

                    <!-- ════════════════════════════════════ -->
                    <!-- TAB 1: RECIBOS                      -->
                    <!-- ════════════════════════════════════ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Receipt" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Recibos"/>
                            </StackPanel>
                        </TabItem.Header>

                        <DockPanel Margin="20">
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                                         md:HintAssist.Hint="Buscar por Nº recibo, beneficiario o concepto..."
                                         md:TextFieldAssist.HasLeadingIcon="True"
                                         md:TextFieldAssist.LeadingIcon="Magnify"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         MaxWidth="450" HorizontalAlignment="Left"/>

                                <Button Grid.Column="1" Command="{Binding NuevoReciboCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        md:ButtonAssist.CornerRadius="6" Padding="16,8"
                                        ToolTip="Crea un recibo en el talonario actualmente seleccionado">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="Plus" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="NUEVO RECIBO"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TabControl SelectedIndex="{Binding SubTabRecibos}"
                                        TabStripPlacement="Top">

                                <!-- ── SUB-TAB: INGRESOS ── -->
                                <TabItem>
                                    <TabItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="ArrowDownBoldCircleOutline"
                                                         Foreground="Green" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="INGRESOS" FontWeight="SemiBold"/>
                                            <Border Background="#E8F5E9" CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding TotalIngresos}" FontSize="11" FontWeight="Bold" Foreground="Green"/>
                                            </Border>
                                        </StackPanel>
                                    </TabItem.Header>

                                    <Grid Margin="0,10,0,0">
                                        <DataGrid ItemsSource="{Binding RecibosIngresos}" IsReadOnly="True"
                                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                                  CanUserDeleteRows="False" SelectionMode="Single"
                                                  CanUserSortColumns="True"
                                                  Style="{StaticResource MaterialDesignDataGrid}"
                                                  md:DataGridAssist.CornerRadius="8"
                                                  HeadersVisibility="Column">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Nº" Binding="{Binding NumeroFormateado}" Width="130">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="Foreground" Value="Green"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}" Width="100"/>
                                                <DataGridTextColumn Header="Beneficiario" Binding="{Binding Beneficiario}" Width="*"/>
                                                <DataGridTextColumn Header="Monto (Bs)" Binding="{Binding Monto, StringFormat=N2}" Width="110">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto}" Width="*"/>
                                                <DataGridTextColumn Header="Cuenta" Binding="{Binding Cuenta}" Width="120"/>
                                                <DataGridTemplateColumn Header="Acciones" Width="150" CanUserSort="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button ToolTip="Imprimir recibo"
                                                                        Command="{Binding DataContext.ImprimirReciboCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                                        Width="32" Height="32"
                                                                        Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                                                    <md:PackIcon Kind="Printer" Width="18" Height="18"/>
                                                                </Button>
                                                                <Button ToolTip="Editar"
                                                                        Command="{Binding DataContext.EditarReciboCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                                        Width="32" Height="32"
                                                                        Visibility="{Binding DataContext.PuedeEditarEliminar, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <md:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                                                </Button>
                                                                <Button ToolTip="Eliminar"
                                                                        Command="{Binding DataContext.PedirEliminarReciboCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                                        Width="32" Height="32" Foreground="OrangeRed"
                                                                        Visibility="{Binding DataContext.PuedeEditarEliminar, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <TextBlock Text="No hay ingresos registrados aún."
                                                   FontSize="13" Foreground="Gray"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40"
                                                   Visibility="{Binding SinResultadosIngresos, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                   IsHitTestVisible="False"/>
                                    </Grid>
                                </TabItem>

                                <!-- ── SUB-TAB: SALIDAS ── -->
                                <TabItem>
                                    <TabItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="ArrowUpBoldCircleOutline"
                                                         Foreground="OrangeRed" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="SALIDAS" FontWeight="SemiBold"/>
                                            <Border Background="#FFEBEE" CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding TotalSalidas}" FontSize="11" FontWeight="Bold" Foreground="OrangeRed"/>
                                            </Border>
                                        </StackPanel>
                                    </TabItem.Header>

                                    <Grid Margin="0,10,0,0">
                                        <DataGrid ItemsSource="{Binding RecibosSalidas}" IsReadOnly="True"
                                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                                  CanUserDeleteRows="False" SelectionMode="Single"
                                                  CanUserSortColumns="True"
                                                  Style="{StaticResource MaterialDesignDataGrid}"
                                                  md:DataGridAssist.CornerRadius="8"
                                                  HeadersVisibility="Column">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Nº" Binding="{Binding NumeroFormateado}" Width="130">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                            <Setter Property="Foreground" Value="OrangeRed"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}" Width="100"/>
                                                <DataGridTextColumn Header="Beneficiario" Binding="{Binding Beneficiario}" Width="*"/>
                                                <DataGridTextColumn Header="Monto (Bs)" Binding="{Binding Monto, StringFormat=N2}" Width="110">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto}" Width="*"/>
                                                <DataGridTextColumn Header="Cuenta" Binding="{Binding Cuenta}" Width="120"/>
                                                <DataGridTemplateColumn Header="Acciones" Width="150" CanUserSort="False">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button ToolTip="Imprimir recibo"
                                                                        Command="{Binding DataContext.ImprimirReciboCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                                        Width="32" Height="32"
                                                                        Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                                                    <md:PackIcon Kind="Printer" Width="18" Height="18"/>
                                                                </Button>
                                                                <Button ToolTip="Editar"
                                                                        Command="{Binding DataContext.EditarReciboCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                                        Width="32" Height="32"
                                                                        Visibility="{Binding DataContext.PuedeEditarEliminar, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <md:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                                                </Button>
                                                                <Button ToolTip="Eliminar"
                                                                        Command="{Binding DataContext.PedirEliminarReciboCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                        CommandParameter="{Binding Id}"
                                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                                        Width="32" Height="32" Foreground="OrangeRed"
                                                                        Visibility="{Binding DataContext.PuedeEditarEliminar, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <md:PackIcon Kind="Delete" Width="18" Height="18"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <TextBlock Text="No hay salidas registradas aún."
                                                   FontSize="13" Foreground="Gray"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40"
                                                   Visibility="{Binding SinResultadosSalidas, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                   IsHitTestVisible="False"/>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </DockPanel>
                    </TabItem>

                    <!-- ════════════════════════════════════ -->
                    <!-- TAB 2: LIBRO DIARIO                 -->
                    <!-- ════════════════════════════════════ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="BookOpenPageVariant" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Libro Diario"/>
                            </StackPanel>
                        </TabItem.Header>

                        <DockPanel Margin="20">
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DatePicker Grid.Column="0" SelectedDate="{Binding DiarioDesde}"
                                            md:HintAssist.Hint="Desde"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                            Width="160"/>
                                <DatePicker Grid.Column="2" SelectedDate="{Binding DiarioHasta}"
                                            md:HintAssist.Hint="Hasta"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                            Width="160"/>
                                <Button Grid.Column="4" Content="FILTRAR"
                                        Command="{Binding FiltrarDiarioCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        md:ButtonAssist.CornerRadius="6" Padding="16,8"/>

                                <!-- Botón GENERAR EXCEL -->
                                <Button Grid.Column="6"
                                        Command="{Binding ExportarLibroDiarioExcelCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        md:ButtonAssist.CornerRadius="6" Padding="16,8"
                                        ToolTip="Generar archivo Excel del Libro Diario">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="MicrosoftExcel" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#1B5E20"/>
                                        <TextBlock Text="GENERAR EXCEL"/>
                                    </StackPanel>
                                </Button>

                                <StackPanel Grid.Column="8" Orientation="Horizontal">
                                    <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                                            BorderThickness="1" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Entradas" FontSize="10"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                                            <TextBlock Text="{Binding TotalEntradas, StringFormat=N2}"
                                                       FontWeight="Bold" Foreground="Green" FontSize="14"/>
                                        </StackPanel>
                                    </Border>
                                    <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                                            BorderThickness="1" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Salidas" FontSize="10"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                                            <TextBlock Text="{Binding TotalSalidasDiario, StringFormat=N2}"
                                                       FontWeight="Bold" Foreground="OrangeRed" FontSize="14"/>
                                        </StackPanel>
                                    </Border>
                                    <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                                            BorderThickness="1" CornerRadius="6" Padding="12,6">
                                        <StackPanel>
                                            <TextBlock Text="Saldo" FontSize="10"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                                            <TextBlock Text="{Binding SaldoFinal, StringFormat=N2}"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                       FontSize="14"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <DataGrid ItemsSource="{Binding MovimientosDiario}" IsReadOnly="True"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      Style="{StaticResource MaterialDesignDataGrid}"
                                      md:DataGridAssist.CornerRadius="8"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}" Width="100"/>
                                    <DataGridTextColumn Header="Detalle" Binding="{Binding Detalle}" Width="*"/>
                                    <DataGridTextColumn Header="Entrada" Binding="{Binding Entrada, StringFormat=N2}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Foreground" Value="Green"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Salida" Binding="{Binding Salida, StringFormat=N2}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Foreground" Value="OrangeRed"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Saldo" Binding="{Binding Saldo, StringFormat=N2}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Concepto" Binding="{Binding Concepto}" Width="*"/>
                                    <DataGridTextColumn Header="Cuenta" Binding="{Binding Cuenta}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>

                    <!-- ════════════════════════════════════ -->
                    <!-- TAB 3: ARQUEO DE CAJA + HISTORIAL    -->
                    <!-- ════════════════════════════════════ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CashCheck" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Arqueo"/>
                            </StackPanel>
                        </TabItem.Header>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                            <StackPanel>
                                <!-- ═══ SECCIÓN 1: NUEVO ARQUEO ═══ -->
                                <md:Card md:ElevationAssist.Elevation="Dp2"
                                         Width="500" HorizontalAlignment="Center"
                                         VerticalAlignment="Top"
                                         Padding="32,32,32,48" Margin="0,20,0,20"
                                         UniformCornerRadius="12">
                                    <StackPanel>
                                        <TextBlock Text="Nuevo Arqueo de Caja" FontSize="22" FontWeight="Bold"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,28"/>

                                        <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                                                CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="SALDO EN CAJA (contable)" FontSize="12"
                                                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                                                    <TextBlock Text="Calculado según registros del libro diario"
                                                               FontSize="10" Foreground="Gray"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" FontSize="24" FontWeight="Bold"
                                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding ArqueoCaja, StringFormat={}{0:N2} Bs}"/>
                                            </Grid>
                                        </Border>

                                        <TextBox Text="{Binding ArqueoFisico, StringFormat=\{0:0.####\}, ConverterCulture=en-US, UpdateSourceTrigger=PropertyChanged}"
                                                 md:HintAssist.Hint="Saldo Físico (conteo manual)"
                                                 b:NumericInput.IsEnabled="True"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 FontSize="18" HorizontalContentAlignment="Right"
                                                 Margin="0,0,0,16"/>

                                        <Border CornerRadius="8" Padding="16" Margin="0,0,0,24"
                                                Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="DIFERENCIA" FontSize="14" FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ArqueoDiferencia, StringFormat=N2}"
                                                           FontSize="24" FontWeight="Bold" VerticalAlignment="Center"
                                                           x:Name="txtDiferencia"/>
                                            </Grid>
                                        </Border>

                                        <TextBox Text="{Binding ArqueoObservaciones, UpdateSourceTrigger=PropertyChanged}"
                                                 md:HintAssist.Hint="Observaciones del arqueo"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 MinHeight="80" Margin="0,0,0,20"/>

                                        <Button Content="GUARDAR ARQUEO"
                                                Command="{Binding GuardarArqueoCommand}"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                md:ButtonAssist.CornerRadius="6"
                                                HorizontalAlignment="Stretch" Height="44"
                                                FontWeight="Bold" Margin="0,0,0,8"/>
                                    </StackPanel>
                                </md:Card>

                                <!-- ═══ SECCIÓN 2: HISTORIAL DE ARQUEOS ═══ -->
                                <Border BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                                        BorderThickness="0,1,0,0" Margin="0,30,0,0" Padding="0,30,0,20">
                                    <StackPanel>
                                        <TextBlock Text="HISTORIAL DE ARQUEOS"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Consulte arqueos anteriores y exporte para enviarlos al Administrador."
                                                   FontSize="12" Foreground="Gray" Margin="0,0,0,16"/>

                                        <!-- Filtros + botones -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <DatePicker Grid.Column="0" SelectedDate="{Binding HistorialDesde}"
                                                        md:HintAssist.Hint="Desde"
                                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                                        Width="160"/>
                                            <DatePicker Grid.Column="2" SelectedDate="{Binding HistorialHasta}"
                                                        md:HintAssist.Hint="Hasta"
                                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                                        Width="160"/>
                                            <Button Grid.Column="4" Content="FILTRAR"
                                                    Command="{Binding FiltrarHistorialArqueosCommand}"
                                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                                    md:ButtonAssist.CornerRadius="6" Padding="16,8"/>

                                            <!-- Botón EXPORTAR (todos los usuarios) -->
                                            <Button Grid.Column="6"
                                                    Command="{Binding ExportarArqueosCommand}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    md:ButtonAssist.CornerRadius="6" Padding="14,8" Margin="0,0,8,0"
                                                    ToolTip="Exporta arqueos pendientes a un archivo .silf-arqueo">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="Upload" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#1565C0"/>
                                                    <TextBlock Text="EXPORTAR"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Botón IMPORTAR (solo Admin) -->
                                            <Button Grid.Column="7"
                                                    Command="{Binding ImportarArqueosCommand}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    md:ButtonAssist.CornerRadius="6" Padding="14,8"
                                                    Visibility="{Binding PuedeImportar, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    ToolTip="Importa un archivo .silf-arqueo del Contador">
                                                <StackPanel Orientation="Horizontal">
                                                    <md:PackIcon Kind="Download" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="#2E7D32"/>
                                                    <TextBlock Text="IMPORTAR"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <!-- Resumen de estados -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <Border Background="#F5F5F5" CornerRadius="14" Padding="12,4" Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Fill="#757575" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="11">
                                                        <Run Text="Pendientes:"/>
                                                        <Run Text="{Binding TotalHistorialPendientes, Mode=OneWay}" FontWeight="Bold"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#E3F2FD" CornerRadius="14" Padding="12,4" Margin="0,0,8,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Fill="#1565C0" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="11">
                                                        <Run Text="Exportados:"/>
                                                        <Run Text="{Binding TotalHistorialExportados, Mode=OneWay}" FontWeight="Bold" Foreground="#1565C0"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                            <Border Background="#E8F5E9" CornerRadius="14" Padding="12,4">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Fill="#2E7D32" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="11">
                                                        <Run Text="Importados:"/>
                                                        <Run Text="{Binding TotalHistorialImportados, Mode=OneWay}" FontWeight="Bold" Foreground="#2E7D32"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- Grid del historial -->
                                        <Grid MinHeight="220">
                                            <DataGrid ItemsSource="{Binding HistorialArqueos}" IsReadOnly="True"
                                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                                      Style="{StaticResource MaterialDesignDataGrid}"
                                                      md:DataGridAssist.CornerRadius="8"
                                                      HeadersVisibility="Column" RowHeight="36">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy HH:mm}" Width="140"/>
                                                    <DataGridTextColumn Header="Contable (Bs)" Binding="{Binding SaldoContable, StringFormat=N2}" Width="110">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Físico (Bs)" Binding="{Binding SaldoFisico, StringFormat=N2}" Width="110">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Diferencia" Binding="{Binding Diferencia, StringFormat=N2}" Width="100">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Realizado por" Binding="{Binding RealizadoPor}" Width="*"/>
                                                    <DataGridTemplateColumn Header="Estado" Width="120" CanUserSort="False">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="10" Padding="8,3"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Border.Background>
                                                                        <SolidColorBrush Color="{Binding EstadoColor}"/>
                                                                    </Border.Background>
                                                                    <TextBlock Text="{Binding EstadoTexto}"
                                                                               FontSize="10" FontWeight="Bold"
                                                                               Foreground="White"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTextColumn Header="Observaciones" Binding="{Binding Observaciones}" Width="200"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock Text="No hay arqueos en el rango seleccionado."
                                                       FontSize="13" Foreground="Gray"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding HistorialSinResultados, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                       IsHitTestVisible="False"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </md:DialogHost>
    </md:DialogHost>
</UserControl>
