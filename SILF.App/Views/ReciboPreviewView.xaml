<!-- Ruta: D:\ARCHIVOS\POTOSI\SILF\SILF.App\Views\ReciboPreviewView.xaml -->
<UserControl x:Class="SILF.App.Views.ReciboPreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SILF.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:ReciboPreviewViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- ═══ BARRA SUPERIOR ═══ -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Command="{Binding VolverCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="ArrowLeft" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="VOLVER A CAJA CHICA"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Command="{Binding ImprimirReciboCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        md:ButtonAssist.CornerRadius="6" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Printer" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="IMPRIMIR"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Command="{Binding ExportarPdfCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        md:ButtonAssist.CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="FilePdfBox" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="EXPORTAR PDF"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ ÁREA DE IMPRESIÓN ═══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="#ECECEC">
            <StackPanel x:Name="PrintArea" HorizontalAlignment="Center" Margin="0,24,0,24">
                <Border Background="White" Width="700" Padding="36,28" BorderBrush="#CCC" BorderThickness="1">
                    <StackPanel>

                        <!-- ═══ COPIA 1 — ORIGINAL ═══ -->
                        <Border BorderBrush="#DDD" BorderThickness="1" Padding="20,16" CornerRadius="2">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding LogoImage}" Width="55" Height="55" Stretch="Uniform" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding EmpresaNombre}" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock FontSize="9" Foreground="Gray"
                                                   Visibility="{Binding TieneNit, Converter={StaticResource BoolVis}}">
                                            <Run Text="NIT: "/><Run Text="{Binding EmpresaNit, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding EmpresaMunicipio, StringFormat=Municipio: {0}}"
                                                   FontSize="9" Foreground="Gray"
                                                   Visibility="{Binding TieneMunicipio, Converter={StaticResource BoolVis}}"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1"
                                            Background="#F5F5F5" Padding="6,3" VerticalAlignment="Top">
                                        <TextBlock Text="ORIGINAL" FontWeight="Bold" FontSize="8" Foreground="#555"/>
                                    </Border>
                                </Grid>
                                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,4,0,8"/>
                                <TextBlock Text="RECIBO DE PAGO" FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,0,0,8"/>
                                <StackPanel HorizontalAlignment="Right" Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="RECIBO Nº  " FontWeight="Bold" FontSize="12"/>
                                        <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="120">
                                            <TextBlock Text="{Binding NumeroReciboFormateado}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="POR:  Bs. " FontWeight="Bold" FontSize="12"/>
                                        <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="90">
                                            <TextBlock Text="{Binding MontoFormateado}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding LabelBeneficiario}" FontWeight="SemiBold" FontSize="11" Margin="0,0,4,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="350">
                                        <TextBlock Text="{Binding Beneficiario}" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="CANTIDAD EN LETRAS:  " FontWeight="SemiBold" FontSize="11"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="320">
                                        <TextBlock Text="{Binding MontoEnLetras}" FontSize="10" TextWrapping="Wrap" MaxWidth="320"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="POR CONCEPTO DE:  " FontWeight="SemiBold" FontSize="11"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="350">
                                        <TextBlock Text="{Binding Concepto}" FontSize="11" TextWrapping="Wrap" MaxWidth="350"/>
                                    </Border>
                                </StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="90" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Fecha, StringFormat=dd/MM/yyyy}" FontSize="10"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding FechaTexto}" FontSize="10" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,35,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Source="{Binding QrImage}" Width="65" Height="65" Stretch="Uniform" VerticalAlignment="Bottom"/>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <Border BorderBrush="Black" BorderThickness="0,0,0,1" Width="170" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding FirmaEntrego}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="ENTREGUÉ CONFORME" FontSize="8" Foreground="Gray" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                        <Border BorderBrush="Black" BorderThickness="0,0,0,1" Width="170" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding FirmaRecibio}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="RECIBÍ CONFORME" FontSize="8" Foreground="Gray" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ═══ LÍNEA DE CORTE ═══ -->
                        <Grid Margin="0,8,0,8" Height="18">
                            <Border Height="1" BorderBrush="#CCC" BorderThickness="0,0,0,1" VerticalAlignment="Center">
                                <Border.Background>
                                    <DrawingBrush TileMode="Tile" Viewport="0,0,8,1" ViewportUnits="Absolute" Stretch="None">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing Brush="#AAA">
                                                <GeometryDrawing.Geometry>
                                                    <RectangleGeometry Rect="0,0,4,1"/>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- ═══ COPIA 2 — EMPRESA ═══ -->
                        <Border BorderBrush="#DDD" BorderThickness="1" Padding="20,16" CornerRadius="2">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding LogoImage}" Width="55" Height="55" Stretch="Uniform" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding EmpresaNombre}" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock FontSize="9" Foreground="Gray"
                                                   Visibility="{Binding TieneNit, Converter={StaticResource BoolVis}}">
                                            <Run Text="NIT: "/><Run Text="{Binding EmpresaNit, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding EmpresaMunicipio, StringFormat=Municipio: {0}}"
                                                   FontSize="9" Foreground="Gray"
                                                   Visibility="{Binding TieneMunicipio, Converter={StaticResource BoolVis}}"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1"
                                            Background="#F5F5F5" Padding="6,3" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding EtiquetaCopiaEmpresa}" FontWeight="Bold" FontSize="8" Foreground="#555"/>
                                    </Border>
                                </Grid>
                                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,4,0,8"/>
                                <TextBlock Text="RECIBO DE PAGO" FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center" FontFamily="Consolas" Margin="0,0,0,8"/>
                                <StackPanel HorizontalAlignment="Right" Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="RECIBO Nº  " FontWeight="Bold" FontSize="12"/>
                                        <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="120">
                                            <TextBlock Text="{Binding NumeroReciboFormateado}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="POR:  Bs. " FontWeight="Bold" FontSize="12"/>
                                        <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="90">
                                            <TextBlock Text="{Binding MontoFormateado}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding LabelBeneficiario}" FontWeight="SemiBold" FontSize="11" Margin="0,0,4,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="350">
                                        <TextBlock Text="{Binding Beneficiario}" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="CANTIDAD EN LETRAS:  " FontWeight="SemiBold" FontSize="11"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="320">
                                        <TextBlock Text="{Binding MontoEnLetras}" FontSize="10" TextWrapping="Wrap" MaxWidth="320"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="POR CONCEPTO DE:  " FontWeight="SemiBold" FontSize="11"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="350">
                                        <TextBlock Text="{Binding Concepto}" FontSize="11" TextWrapping="Wrap" MaxWidth="350"/>
                                    </Border>
                                </StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="Black" BorderThickness="0,0,0,1" MinWidth="90" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Fecha, StringFormat=dd/MM/yyyy}" FontSize="10"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding FechaTexto}" FontSize="10" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,35,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Source="{Binding QrImage}" Width="65" Height="65" Stretch="Uniform" VerticalAlignment="Bottom"/>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <Border BorderBrush="Black" BorderThickness="0,0,0,1" Width="170" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding FirmaEntrego}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="ENTREGUÉ CONFORME" FontSize="8" Foreground="Gray" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                        <Border BorderBrush="Black" BorderThickness="0,0,0,1" Width="170" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding FirmaRecibio}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="RECIBÍ CONFORME" FontSize="8" Foreground="Gray" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
