<!-- Ruta: D:\ARCHIVOS\POTOSI\SILF\SILF.App\Views\MinasView.xaml -->
<UserControl x:Class="SILF.App.Views.MinasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FontFamily="Segoe UI"
             TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock FontSize="12" Opacity="0.5" VerticalAlignment="Center" FontFamily="Montserrat">
                    <Run Text="{Binding Total, Mode=OneWay}"/> <Run Text="minas / parajes"/>
                </TextBlock>
                <Button Style="{StaticResource MaterialDesignRaisedButton}" Background="{DynamicResource MaterialDesign.Brush.Primary}"
                        Command="{Binding NuevoCommand}" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nueva Mina" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" FontSize="13" BorderThickness="1"
                      BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                      materialDesign:DataGridAssist.CornerRadius="8" materialDesign:DataGridAssist.CellPadding="14 10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="FontWeight" Value="SemiBold"/></Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Lotes" Binding="{Binding Cantidad}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/></Style>
                        </DataGridTextColumn.ElementStyle>
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" ToolTip="Editar"
                                            Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                            Command="{Binding DataContext.EditarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32" ToolTip="Eliminar"
                                            Foreground="#E57373"
                                            Command="{Binding DataContext.PedirEliminarCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- DIÁLOGO CREAR/EDITAR -->
        <Border Background="#80000000" Visibility="{Binding DialogoAbierto, Converter={StaticResource BoolToVis}}"/>
        <Border Visibility="{Binding DialogoAbierto, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}" CornerRadius="16" Padding="32" MinWidth="380">
            <Border.Effect><DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.3" Color="Black"/></Border.Effect>
            <StackPanel>
                <TextBlock Text="{Binding DialogoTitulo}" FontSize="18" FontWeight="SemiBold" FontFamily="Montserrat" Margin="0,0,0,20"/>
                <TextBlock Text="Nombre" FontSize="12" FontFamily="Montserrat" FontWeight="Medium" Opacity="0.6" Margin="0,0,0,5"/>
                <TextBox FontSize="13" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Nombre de la mina o paraje" materialDesign:HintAssist.FloatingScale="0.85"
                         Text="{Binding EditNombre, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="{Binding Error}" Foreground="#E57373" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap"
                           Visibility="{Binding HayError, Converter={StaticResource BoolToVis}}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                    <Button Content="Cancelar" Margin="0,0,12,0" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding CancelarDialogoCommand}"/>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Background="{DynamicResource MaterialDesign.Brush.Primary}" Command="{Binding GuardarCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Guardar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- CONFIRMAR ELIMINAR -->
        <Border Background="#80000000" Visibility="{Binding ConfirmarAbierto, Converter={StaticResource BoolToVis}}"/>
        <Border Visibility="{Binding ConfirmarAbierto, Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}" CornerRadius="16" Padding="32" MinWidth="380">
            <Border.Effect><DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.3" Color="Black"/></Border.Effect>
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="AlertCircle" Width="24" Height="24" Foreground="#FFA726" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Confirmar" FontSize="18" FontWeight="SemiBold" FontFamily="Montserrat"/>
                </StackPanel>
                <TextBlock Text="{Binding MensajeConfirmar}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,24" Opacity="0.8"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Margin="0,0,12,0" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding CancelarEliminarCommand}"/>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Background="#E57373"
                            Command="{Binding ConfirmarEliminarCommand}" Visibility="{Binding PuedeEliminar, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Eliminar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
