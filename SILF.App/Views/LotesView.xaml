<!-- Ruta: D:\ARCHIVOS\POTOSI\SILF\SILF.App\Views\LotesView.xaml -->
<UserControl x:Class="SILF.App.Views.LotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource InputFg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputFg}"/>
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#462AD8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EstadoBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ActionIconBtn" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" BorderBrush="Transparent" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource InputBg}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ BANDA INFORMATIVA: PROCESO ACTIVO ═══ -->
        <!-- Solo muestra el proceso actual. El botón FLOTAR vive en el módulo Inv. Flotación. -->
        <Border Grid.Row="0" CornerRadius="8" Margin="0,0,0,10" Padding="14,8"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="InformationOutline" Width="18" Height="18"
                                         Foreground="#462AD8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="{Binding IndicadorProcesoTexto}"
                           FontFamily="Montserrat" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource ExtensionFg}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ FILA DE FILTROS + ACCIONES ═══ -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0" FontSize="13" Height="36" Padding="10,0" VerticalContentAlignment="Center"
                      ItemsSource="{Binding FiltrosEstado}" SelectedItem="{Binding FiltroEstadoSeleccionado}" Margin="0,0,10,0"/>

            <Grid Grid.Column="1" Margin="0,0,10,0">
                <TextBox Style="{StaticResource FieldInput}" Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" Padding="32,0,10,0"/>
                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="{DynamicResource MenuForeground}" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
            </Grid>

            <Button Grid.Column="2" Cursor="Hand" Command="{Binding NuevoLoteCommand}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#462AD8" CornerRadius="8" Padding="18,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Nuevo Lote" Foreground="White" FontFamily="Montserrat" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#5A3DE8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ═══ TABLA DE LOTES ═══ -->
        <Border Grid.Row="2" CornerRadius="12" Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
            <Grid>
                <DataGrid ItemsSource="{Binding LotesFiltrados}" SelectedItem="{Binding LoteSeleccionado}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource PanelBorder}"
                          BorderThickness="0" Background="Transparent" RowBackground="Transparent"
                          FontSize="13" FontFamily="Segoe UI" Foreground="{DynamicResource ExtensionFg}"
                          SelectionMode="Single" SelectionUnit="FullRow" ColumnHeaderHeight="42" RowHeight="48">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource MenuForeground}"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontFamily" Value="Montserrat"/>
                            <Setter Property="Padding" Value="16,0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="16,0"/>
                            <Setter Property="Foreground" Value="{DynamicResource ExtensionFg}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource InputBg}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#12462AD8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nº" Binding="{Binding NumeroLote}" Width="55"/>
                        <DataGridTextColumn Header="PROVEEDOR" Binding="{Binding NombreProveedor}" Width="*"/>
                        <DataGridTextColumn Header="MINA" Binding="{Binding NombreMina}" Width="120"/>
                        <DataGridTextColumn Header="PESO NETO" Binding="{Binding PesoNeto, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="TIPO" Binding="{Binding TipoMineralTexto}" Width="90"/>
                        <DataGridTemplateColumn Header="ESTADO" Width="130" SortMemberPath="EstadoTexto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource EstadoBadge}" Background="{Binding EstadoColor}">
                                        <TextBlock Text="{Binding EstadoTexto}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="FECHA" Binding="{Binding FechaRegistro, StringFormat=dd/MM/yyyy}" Width="95"/>
                        <DataGridTemplateColumn Header="ACCIONES" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource ActionIconBtn}" ToolTip="Recibo de Anticipo (PDF)"
                                                Command="{Binding DataContext.GenerarReciboAnticipoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="FilePdfBox" Width="18" Height="18" Foreground="#C62828"/>
                                        </Button>
                                        <Button Style="{StaticResource ActionIconBtn}" ToolTip="Editar" Margin="4,0,0,0"
                                                Command="{Binding DataContext.EditarLoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" Foreground="#42A5F5"/>
                                        </Button>
                                        <Button Style="{StaticResource ActionIconBtn}" ToolTip="Eliminar" Margin="4,0,0,0"
                                                Command="{Binding DataContext.EliminarLoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16" Foreground="#E57373"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="No se encontraron lotes. Usa el botón + Nuevo Lote para comenzar."
                           Foreground="{DynamicResource MenuForeground}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60"
                           Visibility="{Binding SinResultados, Converter={StaticResource BoolToVis}}" IsHitTestVisible="False"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
