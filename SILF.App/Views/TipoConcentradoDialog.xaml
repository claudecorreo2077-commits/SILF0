<Window x:Class="SILF.App.Views.TipoConcentradoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Tipo de Concentrado" Height="260" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False">

    <Border CornerRadius="12" BorderThickness="1" BorderBrush="#2A2060">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                <GradientStop Color="#0E0C35" Offset="0"/>
                <GradientStop Color="#1B1448" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Nuevo Concentrado" FontSize="16" FontWeight="SemiBold"
                       FontFamily="Montserrat" Foreground="White"/>
            <TextBlock Grid.Row="1" Text="ElegÃ­ el tipo de concentrado a liquidar:"
                       Foreground="#90A4AE" FontSize="12" FontFamily="Montserrat" Margin="0,4,0,14"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Width="170" Height="90" Margin="0,0,10,0" Cursor="Hand" Click="BtnZnAg_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#241B5C" CornerRadius="10" BorderBrush="#3A2E7E" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Cube" Width="30" Height="30" Foreground="#9FA8FF" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Concentrado" Foreground="White" FontSize="13" FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    <TextBlock Text="ZN - AG" Foreground="White" FontSize="15" FontWeight="Bold" FontFamily="Montserrat" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#352A7A"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#6C5DD3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Width="170" Height="90" Cursor="Hand" Click="BtnAg_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#241B5C" CornerRadius="10" BorderBrush="#3A2E7E" BorderThickness="1">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Diamond" Width="30" Height="30" Foreground="#C0C0C0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Concentrado" Foreground="White" FontSize="13" FontFamily="Montserrat" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    <TextBlock Text="AG-PB" Foreground="White" FontSize="15" FontWeight="Bold" FontFamily="Montserrat" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#352A7A"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#6C5DD3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <Button Grid.Row="3" Content="Cancelar" Foreground="#90A4AE" FontFamily="Montserrat" FontSize="12"
                    Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right"
                    Padding="16,8" Margin="0,12,0,0" Click="BtnCancelar_Click"/>
        </Grid>
    </Border>
</Window>
